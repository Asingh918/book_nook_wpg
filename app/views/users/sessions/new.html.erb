<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card shadow-sm mt-3">
      <div class="card-body p-4">
        <h2 style="color:#2d6a4f;" class="mb-4 text-center">Login</h2>

        <%= form_for(resource, as: resource_name, url: user_session_path) do |f| %>
          <% if alert %>
            <div class="alert alert-danger"><%= alert %></div>
          <% end %>

          <div class="mb-3">
            <label class="form-label">Email</label>
            <%= f.email_field :email, class: "form-control" %>
          </div>

          <div class="mb-3">
            <label class="form-label">Password</label>
            <%= f.password_field :password, class: "form-control" %>
          </div>

          <div class="mb-4 d-flex align-items-center gap-2">
            <%= f.check_box :remember_me, class: "form-check-input" %>
            <label class="text-muted">Remember me</label>
          </div>

          <%= f.submit "Login", class: "btn btn-success w-100 py-2" %>
        <% end %>

        <p class="text-center mt-3 text-muted">
          Don't have an account? <%= link_to "Sign Up", new_user_registration_path, style: "color:#2d6a4f;" %>
        </p>
      </div>
    </div>
  </div>
</div>
