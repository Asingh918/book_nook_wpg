<h1 style="color:#2d6a4f;" class="mb-4">🛒 Your Cart</h1>

<% if @cart_items.empty? %>
  <div class="text-center py-5 bg-white rounded border">
    <p class="text-muted mb-3 fs-5">Your cart is empty.</p>
    <%= link_to "Browse Books", root_path, class: "btn btn-success" %>
  </div>
<% else %>
  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card">
        <div class="card-body p-0">
          <% @cart_items.each do |item| %>
            <div class="d-flex align-items-center gap-3 p-3 border-bottom flex-wrap">
              <% if item[:product].image.attached? %>
                <%= image_tag item[:product].image, style: "width:70px; height:90px; object-fit:cover; border-radius:6px;" %>
              <% else %>
                <div style="width:70px; height:90px; background:#e8f5e9; border-radius:6px; display:flex; align-items:center; justify-content:center; font-size:24px;">📚</div>
              <% end %>

              <div class="flex-grow-1">
                <h6 class="mb-1 fw-bold"><%= item[:product].title %></h6>
                <p class="text-muted mb-0" style="font-size:13px;">by <%= item[:product].author %></p>
                <p class="mb-0 fw-bold" style="color:#2d6a4f;">$<%= sprintf('%.2f', item[:product].price_cents / 100.0) %></p>
              </div>

              <div class="d-flex align-items-center gap-2">
                <%= form_with url: cart_update_path, method: :patch, class: "d-flex align-items-center gap-2" do |f| %>
                  <%= f.hidden_field :product_id, value: item[:product].id %>
                  <%= f.number_field :quantity, value: item[:quantity], min: 1, max: 99, class: "form-control form-control-sm", style: "width:65px;" %>
                  <%= f.submit "Update", class: "btn btn-outline-secondary btn-sm" %>
                <% end %>
                <%= button_to "Remove", cart_remove_path(product_id: item[:product].id),
                    method: :delete, class: "btn btn-outline-danger btn-sm" %>
              </div>

              <div class="text-end" style="min-width:80px;">
                <span class="fw-bold" style="color:#2d6a4f;">$<%= sprintf('%.2f', item[:product].price_cents * item[:quantity] / 100.0) %></span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title fw-bold mb-3">Order Summary</h5>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Subtotal</span>
            <span>$<%= sprintf('%.2f', @total / 100.0) %></span>
          </div>
          <hr>
          <div class="d-flex justify-content-between fw-bold fs-5 mb-3">
            <span>Total</span>
            <span style="color:#2d6a4f;">$<%= sprintf('%.2f', @total / 100.0) %></span>
          </div>
          <%= link_to "Proceed to Checkout →", checkout_path, class: "btn btn-success w-100" %>
          <%= link_to "← Continue Shopping", root_path, class: "btn btn-outline-secondary w-100 mt-2" %>
        </div>
      </div>
    </div>
  </div>
<% end %>
