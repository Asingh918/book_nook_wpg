<div style="margin-bottom:32px;">
  <h1 style="color:#2d6a4f; margin:0 0 6px;">Welcome to Book Nook WPG</h1>
  <p style="color:#666; margin:0;">Winnipeg's favourite independent bookstore — now online!</p>
</div>

<%= form_with url: root_path, method: :get, style: "margin-bottom:24px;" do |f| %>
  <div style="display:flex; gap:10px; flex-wrap:wrap;">
    <%= f.text_field :search,
        value: @search_term,
        placeholder: "Search by title or description...",
        style: "flex:1; min-width:200px; padding:10px 14px; border:1px solid #ddd; border-radius:6px; font-size:14px;" %>

    <%= f.select :category_id,
        options_for_select([["All Categories", 0]] + @categories.map { |c| [c.name, c.id] }, @selected_category),
        {},
        { style: "padding:10px 14px; border:1px solid #ddd; border-radius:6px; font-size:14px;" } %>

    <%= f.submit "Search",
        style: "background:#2d6a4f; color:white; padding:10px 20px; border:none; border-radius:6px; font-size:14px; cursor:pointer;" %>

    <% if @search_term.present? || @selected_category > 0 %>
      <%= link_to "Clear", root_path,
          style: "background:#f0f0f0; color:#333; padding:10px 16px; border-radius:6px; text-decoration:none; font-size:14px;" %>
    <% end %>
  </div>
<% end %>

<div style="display:flex; gap:10px; margin-bottom:28px; flex-wrap:wrap;">
  <%= link_to "All Books", root_path,
      style: "background:#{@selected_category == 0 && @search_term.blank? ? '#2d6a4f' : 'white'}; color:#{@selected_category == 0 && @search_term.blank? ? 'white' : '#2d6a4f'}; padding:7px 18px; border-radius:20px; text-decoration:none; font-size:14px; border:1px solid #2d6a4f;" %>
  <% @categories.each do |category| %>
    <%= link_to category.name, root_path(category_id: category.id),
        style: "background:#{@selected_category == category.id ? '#2d6a4f' : 'white'}; color:#{@selected_category == category.id ? 'white' : '#2d6a4f'}; padding:7px 18px; border-radius:20px; text-decoration:none; font-size:14px; border:1px solid #2d6a4f;" %>
  <% end %>
</div>

<% if @search_term.present? %>
  <p style="color:#666; margin-bottom:16px; font-size:14px;">
    Found <strong><%= @products.count %></strong> result(s) for "<strong><%= @search_term %></strong>"
    <% if @selected_category > 0 %>
      in <strong><%= @categories.find { |c| c.id == @selected_category }&.name %></strong>
    <% end %>
  </p>
<% end %>

<% if @products.empty? %>
  <div style="text-align:center; padding:60px; background:white; border-radius:10px; border:1px solid #ddd;">
    <p style="color:#666; font-size:16px; margin:0 0 12px;">No books found.</p>
    <%= link_to "Browse all books", root_path, style: "color:#2d6a4f;" %>
  </div>
<% else %>
  <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:24px;">
    <% @products.each do |product| %>
      <%= render 'product', product: product %>
    <% end %>
  </div>
<% end %>
