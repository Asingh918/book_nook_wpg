<div style="margin-bottom:32px;">
  <h1 style="color:#2d6a4f; margin:0 0 6px;">Welcome to Book Nook WPG</h1>
  <p style="color:#666; margin:0;">Winnipeg's favourite independent bookstore — now online!</p>
</div>

<div style="display:flex; gap:10px; margin-bottom:28px; flex-wrap:wrap;">
  <%= link_to "All Books", root_path, style: "background:#2d6a4f; color:white; padding:7px 18px; border-radius:20px; text-decoration:none; font-size:14px;" %>
  <% @categories.each do |category| %>
    <%= link_to category.name, category_path(category), style: "background:white; color:#2d6a4f; padding:7px 18px; border-radius:20px; text-decoration:none; font-size:14px; border:1px solid #2d6a4f;" %>
  <% end %>
</div>

<div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:24px;">
  <% @products.each do |product| %>
    <%= render 'product', product: product %>
  <% end %>
</div>
