<div style="border:1px solid #ddd; border-radius:10px; overflow:hidden; background:white; box-shadow:0 2px 6px rgba(0,0,0,0.06); display:flex; flex-direction:column;">
  <% if product.image.attached? %>
    <%= image_tag product.image, style: "width:100%; height:200px; object-fit:cover;" %>
  <% else %>
    <div style="width:100%; height:200px; background:#e8f5e9; display:flex; align-items:center; justify-content:center;">
      <span style="font-size:48px;">📚</span>
    </div>
  <% end %>

  <div style="padding:16px; display:flex; flex-direction:column; flex:1;">
    <div>
      <span style="background:#e8f5e9; color:#2d6a4f; padding:3px 10px; border-radius:20px; font-size:12px;">
        <%= product.category.name %>
      </span>
      <h3 style="margin:10px 0 4px; color:#1a1a1a; font-size:16px;"><%= product.title %></h3>
      <p style="margin:0 0 10px; color:#777; font-size:13px;">by <%= product.author %></p>
      <p style="margin:0 0 16px; color:#444; font-size:13px; line-height:1.5;">
        <%= truncate(product.description, length: 120) %>
      </p>
    </div>
    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:auto;">
      <span style="font-size:20px; font-weight:bold; color:#2d6a4f;">
        $<%= sprintf('%.2f', product.price_cents / 100.0) %>
      </span>
      <%= link_to "View Details →", product_path(product), style: "background:#2d6a4f; color:white; padding:7px 16px; border-radius:6px; text-decoration:none; font-size:13px;" %>
    </div>
  </div>
</div>
