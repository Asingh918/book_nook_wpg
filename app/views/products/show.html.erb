<%= breadcrumbs(
  { name: "Home", path: root_path },
  { name: @product.category.name, path: category_path(@product.category) },
  { name: @product.title, path: product_path(@product) }
) %>

<div class="card overflow-hidden mt-2">
  <% if @product.image.attached? %>
    <%= image_tag @product.large_image, style: "width:100%; max-height:400px; object-fit:cover;" %>
  <% else %>
    <div style="width:100%; height:250px; background:#2d6a4f; display:flex; align-items:center; justify-content:center;">
      <div style="text-align:center; padding:20px;">
        <div style="font-size:64px; margin-bottom:12px;">📚</div>
        <h3 style="color:white; margin:0 0 8px;"><%= @product.title %></h3>
        <p style="color:rgba(255,255,255,0.8); margin:0;">by <%= @product.author %></p>
      </div>
    </div>
  <% end %>

  <div class="p-4">
    <div class="d-flex gap-2 mb-3 flex-wrap">
      <span class="category-badge"><%= @product.category.name %></span>
      <% if @product.on_sale? %>
        <span class="badge bg-danger">🏷️ On Sale</span>
      <% end %>
      <% if @product.stock_qty > 0 %>
        <span class="badge bg-success">In Stock (<%= @product.stock_qty %> left)</span>
      <% else %>
        <span class="badge bg-danger">Out of Stock</span>
      <% end %>
      <% @product.tags.each do |tag| %>
        <span class="badge bg-secondary"><%= tag.name %></span>
      <% end %>
    </div>

    <h1 style="color:#1a1a1a;" class="mb-1 fs-3"><%= @product.title %></h1>
    <p class="text-muted fs-5 mb-3">by <%= @product.author %></p>
    <p style="line-height:1.8;" class="mb-4"><%= @product.description %></p>

    <div class="d-flex align-items-center gap-3">
      <span class="price-tag fs-2">$<%= sprintf('%.2f', @product.price_cents / 100.0) %></span>
      <%= button_to "🛒 Add to Cart", cart_add_path(product_id: @product.id),
          method: :post,
          class: "btn btn-success btn-lg" %>
    </div>
  </div>
</div>
