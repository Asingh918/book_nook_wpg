<%= breadcrumbs(
  { name: "Home", path: root_path },
  { name: @product.category.name, path: category_path(@product.category) },
  { name: @product.title, path: product_path(@product) }
) %>

<div class="card" style="overflow:hidden; margin-top:8px;">
  <% if @product.image.attached? %>
    <%= image_tag @product.image, style: "width:100%; max-height:400px; object-fit:cover;" %>
  <% else %>
    <div style="width:100%; height:200px; background:#e8f5e9; display:flex; align-items:center; justify-content:center;">
      <span style="font-size:72px;">📚</span>
    </div>
  <% end %>

  <div style="padding:32px;">
    <div style="display:flex; gap:12px; margin-bottom:16px; flex-wrap:wrap;">
      <span class="badge badge-primary"><%= @product.category.name %></span>
      <% if @product.on_sale? %>
        <span class="badge badge-danger">🏷️ On Sale</span>
      <% end %>
      <% if @product.stock_qty > 0 %>
        <span class="badge badge-success">In Stock (<%= @product.stock_qty %> left)</span>
      <% else %>
        <span class="badge badge-danger">Out of Stock</span>
      <% end %>
    </div>

    <h1 style="color:#1a1a1a; margin:0 0 8px; font-size:26px;"><%= @product.title %></h1>
    <p style="color:#666; font-size:17px; margin:0 0 20px;">by <%= @product.author %></p>
    <p style="color:#333; line-height:1.8; font-size:15px; margin-bottom:32px;"><%= @product.description %></p>

    <div style="display:flex; align-items:center; gap:20px;">
      <span style="font-size:30px; font-weight:bold; color:#2d6a4f;">
        $<%= sprintf('%.2f', @product.price_cents / 100.0) %>
      </span>
      <%= button_to "🛒 Add to Cart", cart_add_path(product_id: @product.id),
          method: :post,
          style: "background:#2d6a4f; color:white; padding:12px 28px; border-radius:8px; border:none; font-size:16px; cursor:pointer;" %>
    </div>
  </div>
</div>
