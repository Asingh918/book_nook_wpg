<!DOCTYPE html>
<html>
  <head>
    <title>Book Nook WPG</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body style="margin:0; font-family:Arial,sans-serif; background:#f9f9f9;">
    <nav style="background:#2d6a4f; padding:14px 32px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
      <a href="/" style="color:white; font-size:22px; font-weight:bold; text-decoration:none;">📚 Book Nook WPG</a>
      <div style="display:flex; gap:16px; align-items:center; flex-wrap:wrap;">
        <a href="/" style="color:white; text-decoration:none; font-size:15px;">Home</a>
        <a href="/cart" style="color:white; text-decoration:none; font-size:15px;">🛒 Cart</a>
        <% if user_signed_in? %>
          <span style="color:#b7e4c7; font-size:14px;">Hi, <%= current_user.first_name %>!</span>
          <a href="/account" style="color:white; text-decoration:none; font-size:15px;">My Account</a>
          <%= button_to "Logout", destroy_user_session_path, method: :delete,
              style: "background:transparent; color:white; border:1px solid white; padding:6px 14px; border-radius:6px; cursor:pointer; font-size:14px;" %>
        <% else %>
          <%= link_to "Login", new_user_session_path, style: "color:white; text-decoration:none; font-size:15px;" %>
          <%= link_to "Sign Up", new_user_registration_path, style: "background:white; color:#2d6a4f; padding:6px 14px; border-radius:6px; text-decoration:none; font-size:14px; font-weight:bold;" %>
        <% end %>
      </div>
    </nav>

    <% if notice %>
      <div style="background:#d4edda; color:#155724; padding:10px 32px; border-bottom:1px solid #c3e6cb;">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div style="background:#f8d7da; color:#721c24; padding:10px 32px; border-bottom:1px solid #f5c6cb;">
        <%= alert %>
      </div>
    <% end %>

    <main style="max-width:1100px; margin:0 auto; padding:32px 24px;">
      <%= yield %>
    </main>

    <footer style="background:#2d6a4f; color:white; text-align:center; padding:20px; margin-top:60px;">
      <p style="margin:0;">© 2024 Book Nook WPG — Winnipeg's Independent Bookstore</p>
    </footer>
  </body>
</html>
