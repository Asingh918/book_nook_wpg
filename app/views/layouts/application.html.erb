<!DOCTYPE html>
<html>
  <head>
    <title>Book Nook WPG</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body style="margin:0; font-family:Arial,sans-serif; background:#f9f9f9;">
    <nav style="background:#2d6a4f; padding:14px 32px; display:flex; justify-content:space-between; align-items:center;">
      <a href="/" style="color:white; font-size:22px; font-weight:bold; text-decoration:none;">📚 Book Nook WPG</a>
      <div style="display:flex; gap:20px; align-items:center;">
        <a href="/" style="color:white; text-decoration:none; font-size:15px;">Home</a>
        <a href="/cart" style="color:white; text-decoration:none; font-size:15px;">🛒 Cart</a>
      </div>
    </nav>
    <% if notice %>
      <div style="background:#d4edda; color:#155724; padding:10px 32px; border-bottom:1px solid #c3e6cb;">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div style="background:#f8d7da; color:#721c24; padding:10px 32px; border-bottom:1px solid #f5c6cb;">
        <%= alert %>
      </div>
    <% end %>
    <main style="max-width:1100px; margin:0 auto; padding:32px 24px;">
      <%= yield %>
    </main>
    <footer style="background:#2d6a4f; color:white; text-align:center; padding:20px; margin-top:60px;">
      <p style="margin:0;">© 2024 Book Nook WPG — Winnipeg's Independent Bookstore</p>
    </footer>
  </body>
</html>
