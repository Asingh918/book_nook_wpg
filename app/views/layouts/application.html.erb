<!DOCTYPE html>
<html>
  <head>
    <title>Book Nook WPG</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <nav style="background:#2d6a4f; padding:12px 24px; display:flex; justify-content:space-between; align-items:center;">
      <a href="/" style="color:white; font-size:22px; font-weight:bold; text-decoration:none;">📚 Book Nook WPG</a>
      <div style="display:flex; gap:16px;">
        <a href="/" style="color:white; text-decoration:none;">Home</a>
        <a href="/cart" style="color:white; text-decoration:none;">🛒 Cart</a>
      </div>
    </nav>

    <% if notice %>
      <div style="background:#d4edda; color:#155724; padding:10px 24px; border-bottom:1px solid #c3e6cb;">
        <%= notice %>
      </div>
    <% end %>

    <% if alert %>
      <div style="background:#f8d7da; color:#721c24; padding:10px 24px; border-bottom:1px solid #f5c6cb;">
        <%= alert %>
      </div>
    <% end %>

    <main style="max-width:1100px; margin:0 auto; padding:24px;">
      <%= yield %>
    </main>

    <footer style="background:#2d6a4f; color:white; text-align:center; padding:16px; margin-top:40px;">
      <p>© 2024 Book Nook WPG — Winnipeg's Independent Bookstore</p>
    </footer>
  </body>
</html>
