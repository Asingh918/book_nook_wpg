<!DOCTYPE html>
<html>
  <head>
    <title>Book Nook WPG</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg" style="background:#2d6a4f;">
      <div class="container">
        <a class="navbar-brand text-white fw-bold fs-4" href="/">📚 Book Nook WPG</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
          style="border-color:rgba(255,255,255,0.5);">
          <span class="navbar-toggler-icon" style="filter:invert(1);"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto align-items-lg-center gap-2">
            <li class="nav-item">
              <a class="nav-link text-white" href="/">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link text-white" href="/about">About</a>
            </li>
            <li class="nav-item">
              <a class="nav-link text-white" href="/contact">Contact</a>
            </li>
            <li class="nav-item">
              <a class="nav-link text-white" href="/cart">🛒 Cart</a>
            </li>
            <% if user_signed_in? && current_user.is_a?(User) %>
              <li class="nav-item">
                <a class="nav-link text-white" href="/orders">My Orders</a>
              </li>
              <li class="nav-item">
                <a class="nav-link text-white" href="/account">My Account</a>
              </li>
              <li class="nav-item">
                <span class="nav-link" style="color:#b7e4c7;">Hi, <%= current_user.first_name %>!</span>
              </li>
              <li class="nav-item">
                <%= button_to "Logout", destroy_user_session_path, method: :delete,
                    class: "btn btn-outline-light btn-sm" %>
              </li>
            <% else %>
              <li class="nav-item">
                <a class="nav-link text-white" href="/users/sign_in">Login</a>
              </li>
              <li class="nav-item">
                <a class="btn btn-light btn-sm fw-bold" style="color:#2d6a4f;" href="/users/sign_up">Sign Up</a>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="flash-notice"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="flash-alert"><%= alert %></div>
    <% end %>

    <main class="container py-4">
      <%= yield %>
    </main>

    <footer style="background:#1a3d2e;" class="text-white mt-5 py-5">
      <div class="container">
        <div class="row g-4">
          <div class="col-md-4">
            <h5 class="fw-bold mb-3">📚 Book Nook WPG</h5>
            <p style="color:rgba(255,255,255,0.7); font-size:14px;">Winnipeg's favourite independent bookstore since 2011. We love books and the people who read them.</p>
          </div>
          <div class="col-md-4">
            <h6 class="fw-bold mb-3">Quick Links</h6>
            <ul class="list-unstyled" style="font-size:14px;">
              <li class="mb-1"><a href="/" class="text-white text-decoration-none">Home</a></li>
              <li class="mb-1"><a href="/about" class="text-white text-decoration-none">About Us</a></li>
              <li class="mb-1"><a href="/contact" class="text-white text-decoration-none">Contact</a></li>
              <li class="mb-1"><a href="/cart" class="text-white text-decoration-none">Shopping Cart</a></li>
            </ul>
          </div>
          <div class="col-md-4">
            <h6 class="fw-bold mb-3">Categories</h6>
            <ul class="list-unstyled" style="font-size:14px;">
              <% Category.all.each do |cat| %>
                <li class="mb-1">
                  <a href="/categories/<%= cat.id %>" class="text-white text-decoration-none"><%= cat.name %></a>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
        <hr style="border-color:rgba(255,255,255,0.2); margin:24px 0;">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
          <p class="mb-0" style="font-size:13px; color:rgba(255,255,255,0.7);">© 2024 Book Nook WPG — Winnipeg, Manitoba</p>
          <p class="mb-0" style="font-size:13px; color:rgba(255,255,255,0.7);">Made with ❤️ for book lovers</p>
        </div>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
