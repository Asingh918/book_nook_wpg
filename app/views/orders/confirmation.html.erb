<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="text-center py-4">
      <div style="font-size:64px;">🎉</div>
      <h1 style="color:#2d6a4f;" class="mt-2 mb-1">Order Confirmed!</h1>
      <p class="text-muted">Thank you for your order. Order #<%= @order.id %></p>
    </div>

    <div class="card mb-4">
      <div class="card-header fw-bold">Order Details</div>
      <div class="card-body p-0">
        <% @order.order_items.each do |item| %>
          <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
            <div>
              <p class="mb-0 fw-bold"><%= item.product.title %></p>
              <small class="text-muted">Qty: <%= item.quantity %></small>
            </div>
            <span>$<%= sprintf('%.2f', item.unit_price_cents * item.quantity / 100.0) %></span>
          </div>
        <% end %>
        <div class="p-3">
          <div class="d-flex justify-content-between text-muted mb-1">
            <span>Subtotal</span>
            <span>$<%= sprintf('%.2f', @order.subtotal_cents / 100.0) %></span>
          </div>
          <div class="d-flex justify-content-between text-muted mb-2">
            <span>Tax</span>
            <span>$<%= sprintf('%.2f', @order.tax_cents / 100.0) %></span>
          </div>
          <hr>
          <div class="d-flex justify-content-between fw-bold fs-5">
            <span>Total</span>
            <span style="color:#2d6a4f;">$<%= sprintf('%.2f', @order.total_cents / 100.0) %></span>
          </div>
        </div>
      </div>
    </div>

    <div class="text-center">
      <%= link_to "View My Orders", orders_path, class: "btn btn-outline-success me-2" %>
      <%= link_to "Continue Shopping", root_path, class: "btn btn-success" %>
    </div>
  </div>
</div>
