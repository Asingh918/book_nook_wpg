<h1 style="color:#2d6a4f;" class="mb-4">My Orders</h1>

<% if @orders.empty? %>
  <div class="text-center py-5 bg-white rounded border">
    <p class="text-muted mb-3 fs-5">You have no orders yet.</p>
    <%= link_to "Browse Books", root_path, class: "btn btn-success" %>
  </div>
<% else %>
  <% @orders.each do |order| %>
    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
          <span class="fw-bold">Order #<%= order.id %></span>
          <span class="text-muted ms-2" style="font-size:13px;"><%= order.created_at.strftime("%B %d, %Y") %></span>
        </div>
        <div class="d-flex align-items-center gap-3">
          <span class="badge <%= order.status == 'paid' ? 'bg-success' : order.status == 'shipped' ? 'bg-primary' : 'bg-warning text-dark' %>">
            <%= order.status.capitalize %>
          </span>
          <span class="fw-bold" style="color:#2d6a4f;">$<%= sprintf('%.2f', order.total_cents / 100.0) %></span>
        </div>
      </div>
      <div class="card-body p-0">
        <% order.order_items.each do |item| %>
          <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
            <div>
              <p class="mb-0 fw-bold"><%= item.product.title %></p>
              <small class="text-muted">Qty: <%= item.quantity %> × $<%= sprintf('%.2f', item.unit_price_cents / 100.0) %></small>
            </div>
            <span>$<%= sprintf('%.2f', item.unit_price_cents * item.quantity / 100.0) %></span>
          </div>
        <% end %>
        <div class="p-3">
          <div class="d-flex justify-content-between text-muted mb-1">
            <small>Subtotal</small>
            <small>$<%= sprintf('%.2f', order.subtotal_cents / 100.0) %></small>
          </div>
          <div class="d-flex justify-content-between text-muted mb-2">
            <small>Tax</small>
            <small>$<%= sprintf('%.2f', order.tax_cents / 100.0) %></small>
          </div>
          <div class="d-flex justify-content-between fw-bold">
            <span>Total</span>
            <span style="color:#2d6a4f;">$<%= sprintf('%.2f', order.total_cents / 100.0) %></span>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
